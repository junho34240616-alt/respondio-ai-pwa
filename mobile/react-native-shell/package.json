{
  "name": "respondio-react-native-shell",
  "private": true,
  "version": "0.1.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "doctor": "node ./scripts/doctor.mjs",
    "start": "EXPO_NO_TELEMETRY=1 ./scripts/use-node20.sh expo start",
    "start:lan": "EXPO_NO_TELEMETRY=1 ./scripts/use-node20.sh expo start --lan --port 8081 --clear",
    "start:offline": "EXPO_NO_TELEMETRY=1 ./scripts/use-node20.sh expo start --offline --port 8081 --clear",
    "android": "./scripts/use-node20.sh expo run:android",
    "ios": "./scripts/use-node20.sh expo run:ios",
    "web": "EXPO_NO_TELEMETRY=1 ./scripts/use-node20.sh expo start --web",
    "export:android": "EXPO_NO_TELEMETRY=1 ./scripts/use-node20.sh expo export --platform android --output-dir ./dist-export"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "babel-preset-expo": "~54.0.0"
  }
}
